{
  "name": "subscription-tracker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
"scripts": {
    "start": "node app.js",
    "dev:node": "nodemon app.js",
    "dev:qstash": "npx @upstash/qstash-cli dev",
    "dev": "concurrently -k -p \"[{name}]\" -n \"NODE,QSTASH\" -c \"cyan,magenta\" \"npm run dev:node\" \"npm run dev:qstash\""
  },
  "dependencies": {
    "@arcjet/inspect": "^1.8.0",
    "@arcjet/node": "^1.8.0",
    "@upstash/workflow": "^1.3.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "~1.4.4",
    "dayjs": "^1.11.21",
    "debug": "~2.6.9",
    "dotenv": "^17.4.2",
    "express": "~4.16.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.4.0",
    "mongoose": "^9.7.3",
    "morgan": "~1.9.1",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14"
  }
}
